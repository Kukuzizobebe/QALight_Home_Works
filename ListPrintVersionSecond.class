import java.util.*;

public class Main {
    public static void main(String[] args) {
        List<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Cherry");

        System.out.println("\nforeach:");
        for (String item : list) {
            System.out.println(item);
        }
    }
}
